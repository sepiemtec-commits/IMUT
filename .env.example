# ─── Geral ───────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3000
API_URL=http://localhost:3000
APP_URL=http://localhost:8081
CORS_ORIGIN=http://localhost:8081

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://imut:imut_secret@localhost:5432/imut?schema=public

# ─── Redis / BullMQ ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
TRUST_PROXY=true
FORCE_HTTPS=true

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price recorrente mensal (mode=subscription no Checkout)
STRIPE_PRICE_ID_MONTHLY=price_...

# ─── HiveMQ Cloud (MQTT) ─────────────────────────────────────────────────────
MQTT_BROKER_URL=mqtts://your-cluster.s1.eu.hivemq.cloud:8883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=imut

# ─── E-mail (alertas + relatórios) — Nodemailer ───────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
EMAIL_FROM=alertas@imut.app
REPORTS_STORAGE_PATH=storage/reports

# ─── Firebase Cloud Messaging (push) ─────────────────────────────────────────
# Opção A: arquivo JSON da service account
FCM_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Opção B: variáveis individuais
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# ─── IA (análise estatística / TensorFlow futuro) ───────────────────────────────
ML_BACKEND=statistical
ML_MODEL_PATH=./models/temperature

# ─── Mobile (Expo) ─────────────────────────────────────────────────────────────
# Celular: use IP do PC (hostname -I), não localhost
EXPO_PUBLIC_API_URL=http://192.168.0.23:3000
EXPO_PUBLIC_EAS_PROJECT_ID=
